# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001                          # Railway sets this automatically
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_string_min_32_chars

# ── Database ──────────────────────────────────────────────────────────────────
# Railway Volume: mount a volume at /data in Railway dashboard, then set:
DATA_DIR=/data

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://sanathanatattva.shop   # your Netlify frontend URL

# ── Twilio Verify (Delivery OTP) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret
# Set in Razorpay Dashboard → Webhooks; used to HMAC-verify incoming events.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Email OTP (optional — leave blank for console/dev mode) ──────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Sanathana Tattva <your@gmail.com>

# ── Business identity (printed on GST invoices) ──────────────────────────────
# BUSINESS_NAME = registered legal entity (the GSTIN holder)
# BUSINESS_BRAND = customer-facing trading name shown as a subtitle
BUSINESS_NAME=Gravity Traders
BUSINESS_BRAND=SanathanaTattva
BUSINESS_ADDRESS=Your registered office address, City, PIN
BUSINESS_GSTIN=29AIGPB6124Q2ZW
BUSINESS_STATE=Karnataka
BUSINESS_EMAIL=namaste@sanathanatattva.shop
BUSINESS_PHONE=+91-XXXXXXXXXX
