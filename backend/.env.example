# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001                          # Railway sets this automatically
NODE_ENV=production

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_string_min_32_chars

# ── Database ──────────────────────────────────────────────────────────────────
# Railway Volume: mount a volume at /data in Railway dashboard, then set:
DATA_DIR=/data

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://sanathanatattva.shop   # your Netlify frontend URL

# ── Twilio Verify (Delivery OTP) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Razorpay (Payments) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_secret

# ── Email OTP (optional — leave blank for console/dev mode) ──────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Sanathana Tattva <your@gmail.com>
