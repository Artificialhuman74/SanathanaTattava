# Set this in Netlify → Site Settings → Environment Variables
# Point it to wherever your laptop backend is exposed publicly
# (ngrok, cloudflared tunnel, or your router's public IP + port)
#
# Examples:
#   VITE_API_URL=https://abc123.ngrok-free.app
#   VITE_API_URL=https://tradehub.yourdomain.com
#   VITE_API_URL=http://YOUR_PUBLIC_IP:5001
VITE_API_URL=https://YOUR_BACKEND_URL_HERE

# Optional fallbacks (comma-separated). App auto-fails over in this order:
#   VITE_API_URL -> VITE_API_URL_CANDIDATES -> VITE_API_URL_FALLBACK
# VITE_API_URL_CANDIDATES=https://backup-1.example.com,https://backup-2.example.com
# VITE_API_URL_FALLBACK=https://api.example.com

# ── Firebase (consumer Google sign-in) ────────────────────────────────
# Get these from Firebase console → Project settings → Your apps → Web app.
# The apiKey is safe to expose (it's an identifier, not a secret).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
